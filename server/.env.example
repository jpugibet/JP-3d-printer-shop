# Database Configuration
# For Railway Postgres (automatically set by Railway if you add a Postgres database)
# DATABASE_URL=postgresql://user:password@hostname:port/database

# For Neon Database (external)
# DATABASE_URL=postgresql://neondb_owner:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Server Configuration
PORT=3000
NODE_ENV=production

# Frontend URL (update after deploying to Netlify)
FRONTEND_URL=https://your-app.netlify.app

# Webhook de Relay para flujos de contacto
# Coloca la URL que te proporciona Relay aquí. Ej:
# RELAY_CONTACT_WEBHOOK_URL=https://hook.relay.app/xxxx
RELAY_CONTACT_WEBHOOK_URL=https://hook.relay.app/api/v1/playbook/cmm9ii8tp07gu0om2abynhak5/trigger/fw-IHgL1ZwzCxi26JDSBKQ

# Notes:
# - DATABASE_URL must include SSL parameters for production (?sslmode=require)
# - PORT is usually set automatically by Railway
# - NODE_ENV should be 'production' in Railway
# - FRONTEND_URL is used for CORS configuration
